# Copy to `.env` (or create `.env` with the same keys). Never commit real keys.
#
# Recommended for this project: Ollama Cloud
# 1. Create a key: https://ollama.com/settings/keys
# 2. Put it in `.env` as OLLAMA_API_KEY=your_key_here (no quotes)

# --- Ollama Cloud (OpenAI-compatible: https://ollama.com/v1) ---
# Docs: https://docs.ollama.com/cloud — cloud models: https://ollama.com/search?c=cloud
# List tags: curl https://ollama.com/api/tags
OLLAMA_API_KEY=
# Ollama Cloud: use a tag from https://ollama.com/search?c=cloud (e.g. gpt-oss:120b). Local: llama3.1:8b + OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gpt-oss:120b
# API base (OLLAMA_CLOUD_BASE_URL wins over OLLAMA_BASE_URL; default is ollama.com/v1)
# OLLAMA_BASE_URL=https://ollama.com/v1
# OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
# If OPENAI_API_KEY is also set: 1=use Ollama, 0=no=prefer OpenAI
# USE_OLLAMA=1

# OpenAI (optional if you use Ollama Cloud only)
OPENAI_API_KEY=

# Force provider if both keys exist: openai | ollama_cloud
# LLM_PROVIDER=ollama_cloud

# Optional model override when using OpenAI
# OPENAI_MODEL=gpt-4o-mini
